@using ASPZIZ_PK_New.Features.Admin.Models
@using Microsoft.AspNetCore.Components.Forms
@rendermode InteractiveServer

<style>
    .wrap-cell {
        white-space: normal !important;
        word-break: break-word;
        line-height: 1.4;
        padding: 0.25rem 0.5rem; /* соответствует Compact-режиму */
    }
</style>

<div id="commandcontainer" class="m-3">
    <a class="btn btn-success" id="newButton" href="@($"admin/VuzSpec/create{(SelectedFacultyId.HasValue ? "/" + SelectedFacultyId.Value.ToString() : "")}")"><i class="bi bi-plus-circle"></i> Создать </a>
    <button class="btn btn-primary ms-1" id="detailsButton" @onclick="OnDetails"><i class="bi bi-pencil"></i> Изменить </button>
    <button class="btn btn-danger ms-1" id="deleteButton" @onclick="OnDelete"><i class="bi bi-trash"></i> Удалить</button>
</div>

<!-- Filters -->
<div class="mb-3 row align-items-center">
    <div class="col-auto">
        <label class="form-label mb-0">Факультет</label>
        <InputSelect TValue="short?" class="form-select" @bind-Value="SelectedFacultyId">
            <option value="">Все факультеты</option>
            @foreach (var f in faculties)
            {
                <option value="@f.FacltId">@f.FacltNameRu</option>
            }
        </InputSelect>
    </div>

    <div class="col-auto ms-3">
        <div class="form-check mt-3">
            <InputCheckbox class="form-check-input" @bind-Value="ShowCelevOnly" />
            <label class="form-check-label">Показать только целевые</label>
        </div>
    </div>
</div>

<RadzenDataGrid Data="@displayedSpecialities" TItem="SpecialityListModel"
                Density="Density.Compact"
                AllowFiltering="false" AllowColumnResize="true" AllowAlternatingRows="true"
                FilterMode="FilterMode.Advanced" AllowSorting="false"
                RowRender="@OnRowRender"
                ColumnWidth="auto"
                LogicalFilterOperator="LogicalFilterOperator.Or"
                SelectionMode="DataGridSelectionMode.Single" @bind-Value="@selectedSpecialities">
    <Columns>
        <RadzenDataGridColumn Title="Факультет" Width="150px">
            <Template Context="item">
                <div class="wrap-cell">@item.FacultyName</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Название" Width="200px">
            <Template Context="item">
                <div class="wrap-cell">@item.SpecialityName</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Форма обучения" Width="100px">
            <Template Context="item">
                <div class="wrap-cell">@item.ObrFormaName</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Вид обучения" Width="120px">
            <Template Context="item">
                <div class="wrap-cell">@item.ObrVidName</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Оплата" Width="80px">
            <Template Context="item">
                <div class="wrap-cell">@item.Oplata</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Срок обучения" Width="100px">
            <Template Context="item">
                <div class="wrap-cell">@item.Srok</div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="План приема" Width="100px">
            <Template Context="item">
                <div class="wrap-cell">@item.KolvoMest</div>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    [Inject] ISender Sender { get; set; }
    [Inject] NavigationManager Navigation { get; set; }
    [Inject] DialogService DialogService { get; set; }

    // data
    List<SpecialityListModel> specialities = new();
    IEnumerable<SpecialityListModel> displayedSpecialities => specialities
        .Where(s => (!showCelevOnly || s.CelevB));

    // faculties for filter
    List<FacultyListModel> faculties = new();

    // selected values for filters
    short? selectedFacultyId;
    bool showCelevOnly = false;

    IList<SpecialityListModel> selectedSpecialities;

    protected override async Task OnInitializedAsync()
    {
        // load faculties for dropdown
        var facs = await Sender.Send(new GetFacultiesList());
        faculties = facs?.ToList() ?? new List<FacultyListModel>();

        // initial load of specialities (no faculty filter)
        await LoadSpecialitiesAsync();
        selectedSpecialities = new List<SpecialityListModel>() { displayedSpecialities.FirstOrDefault() };
    }

    async Task LoadSpecialitiesAsync()
    {
        // request from server by faculty (server will filter by faculty if provided)
        var list = await Sender.Send(new GetSpecialitiesList(selectedFacultyId));
        specialities = list?.ToList() ?? new List<SpecialityListModel>();

        // apply client-side 'celev' filter via displayedSpecialities getter
        // reset selection to first item if any
        selectedSpecialities = new List<SpecialityListModel>() { displayedSpecialities.FirstOrDefault() };
        await InvokeAsync(StateHasChanged);
    }

    // single correct handler for change events
    async Task OnFilterChanged(ChangeEventArgs _)
    {
        await LoadSpecialitiesAsync();
    }

    void OnRowRender(RowRenderEventArgs<SpecialityListModel> args)
    {
        // добавляем атрибут двойного клика
        args.Attributes["ondblclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, OnDetails);
    }

    void OnDetails()
    {
        if (selectedSpecialities?.Any() != true) return;
        Navigation.NavigateTo($"admin/speciality/details/{selectedSpecialities.First().VuzSpecId}");
    }

    private async Task OnDelete(MouseEventArgs args)
    {
        if (selectedSpecialities?.Any() != true) return;

        var result = await DialogService.Confirm(
            message: $"{selectedSpecialities.First().SpecialityName}",
            title: "Вы уверены, что хотите удалить?",
            options: new ConfirmOptions() { OkButtonText = "Да", CancelButtonText = "Нет" }
        );

        // implement deletion when confirmed
    }

    // backing fields
    //short? selectedFacultyId;
    //bool showCelevOnly = false;

    public short? SelectedFacultyId
    {
        get => selectedFacultyId;
        set
        {
            if (selectedFacultyId != value)
            {
                selectedFacultyId = value;
                // fire-and-forget safe call — можно Await через InvokeAsync
                _ = LoadSpecialitiesAsync();
            }
        }
    }

    public bool ShowCelevOnly
    {
        get => showCelevOnly;
        set
        {
            if (showCelevOnly != value)
            {
                showCelevOnly = value;
                _ = LoadSpecialitiesAsync();
            }
        }
    }
}
