@using System.Diagnostics
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject DialogService DialogService

<div id="commandcontainer" class="m-3">
    <a class="btn btn-success" id="newButton" href="admin/OKSK/create"><i class="bi bi-plus-circle"></i> Создать </a>
    <button class="btn btn-primary ms-1" id="detailsButton" @onclick="OnDetails"><i class="bi bi-pencil"></i> Изменить </button>
    <button class="btn btn-danger ms-1" id="deleteButton" @onclick="OnDelete" disabled="@(!CanDelete)">
        <i class="bi bi-trash"></i> Удалить </button>
</div>

<RadzenDataGrid Data="@specialities" TItem="OKSKModel"
                Density="Density.Compact"
                AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="true"
                FilterMode="FilterMode.Advanced" AllowSorting="true"
                RowRender="@OnRowRender"
                ColumnWidth="300px" LogicalFilterOperator="LogicalFilterOperator.Or"
                SelectionMode="DataGridSelectionMode.Single" @bind-Value="@selectedSpecialities">
    <Columns>
        <RadzenDataGridColumn Property="@nameof(OKSKModel.Name)" Title="Название" />
        <RadzenDataGridColumn Property="@nameof(OKSKModel.Abbr)" Title="Аббревиатура" />
        <RadzenDataGridColumn Property="@nameof(OKSKModel.Code)" Title="Код" />
        <RadzenDataGridColumn Property="@nameof(OKSKModel.Kvalif)" Title="Квалификация" />
        <RadzenDataGridColumn Property="@nameof(OKSKModel.CountUsed)" Title="Специальностей" />
    </Columns>
</RadzenDataGrid>

@code {
    [Inject] ISender Sender { get; set; }
    [Inject] NavigationManager Navigation { get; set; }

    IQueryable<OKSKModel> specialities;
    IList<OKSKModel> selectedSpecialities;

    protected override async Task OnInitializedAsync()
    {
        await LoadListAsync();
    }

    async Task LoadListAsync()
    {
        specialities = (await Sender.Send(new GetOKSKList())).AsQueryable();
        selectedSpecialities = new List<OKSKModel>() { specialities.FirstOrDefault() };
        await InvokeAsync(StateHasChanged);
    }

    bool CanDelete => selectedSpecialities?.Any() == true;

    void OnRowRender(RowRenderEventArgs<OKSKModel> args)
    {
        // keep double-click to navigate
        args.Attributes["ondblclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, OnDetails);
    }

    void OnDetails()
    {
        if (selectedSpecialities == null || !selectedSpecialities.Any()) return;
        Navigation.NavigateTo($"admin/OKSK/details/{selectedSpecialities.First().Id}");
    }

    private async Task OnDelete(MouseEventArgs args)
    {
        if (!CanDelete) return;

        var names = string.Join(", ", selectedSpecialities.Select(s => s.Name));
        var confirm = await DialogService.Confirm(
            message: $"Удалить выбранную специальность: {names} ?",
            title: "Подтвердите удаление",
            options: new ConfirmOptions() { OkButtonText = "Да", CancelButtonText = "Нет" }
        );

        if (confirm != true) return;

        try
        {
            var id = selectedSpecialities.First().Id;//(s => s.Id).ToList();
            await Sender.Send(new DeleteOkskSpecsCommand(id));
            await LoadListAsync();
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"Error deleting OKSK: {ex.Message}");
        }
    }
}
